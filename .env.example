# SequrAI — environment variables (no secrets)
# Copy to .env.local and fill in values from Supabase / GitHub / Vercel.

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional product documentation URL (shown in Workspace Switcher when set)
# NEXT_PUBLIC_DOCS_URL=https://docs.sequrai.com

# ─── Supabase (required) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GitHub (required for Continuous Reviews in production) ───────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# Optional override for webhook URL registration
# GITHUB_WEBHOOK_URL=https://your-domain.com/api/webhooks/github

# Encrypt GitHub OAuth tokens at rest (recommended for private beta)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# GITHUB_TOKEN_ENCRYPTION_KEY=

# ─── AI (optional — AI summaries degrade gracefully without it) ───────────────
# ANTHROPIC_API_KEY=

# ─── Email (optional) ───────────────────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Stripe (optional — billing not required for Builder Edition beta) ───────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_BUILDER_PRICE_ID=
# STRIPE_STUDIO_PRICE_ID=
# STRIPE_AGENCY_PRICE_ID=

# ─── Development only — NEVER set in production ─────────────────────────────
# SEQURAI_BYPASS_AUTH=false
